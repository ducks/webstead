<div class="max-w-2xl mx-auto py-24 px-6 text-center">
  <h1 class="text-5xl font-bold text-gray-900 mb-6">Webstead</h1>
  <p class="text-xl text-gray-600 mb-8">
    Your own corner of the web. A personal site that federates.
  </p>
  <div class="space-x-4">
    <%= link_to "Create your webstead", signup_path,
      class: "inline-block bg-gray-900 text-white px-6 py-3 rounded-lg hover:bg-gray-800" %>
    <%= link_to "Sign in", login_path,
      class: "inline-block border border-gray-300 text-gray-700 px-6 py-3 rounded-lg hover:bg-gray-50" %>
  </div>
</div>
