# Kamal secrets - copy to .kamal/secrets and fill in actual values
# Never commit .kamal/secrets to git!

# GHCR registry credentials (generate a Personal Access Token with packages:write)
KAMAL_REGISTRY_USERNAME=your_github_username
KAMAL_REGISTRY_PASSWORD=ghp_your_personal_access_token

# Rails master key (from config/master.key or generate with: rails secret)
RAILS_MASTER_KEY=your_master_key_here

# Secret key base (generate with: bin/rails secret)
SECRET_KEY_BASE=your_secret_key_base_here

# PostgreSQL password (used by both the app and the db accessory)
WEBSTEAD_DATABASE_PASSWORD=your_postgres_password_here
